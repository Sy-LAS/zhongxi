# 强制使用 Wayland，如果 Wayland 不可用可改为 xcb
export QT_QPA_PLATFORM=${QT_QPA_PLATFORM:-wayland-egl}
# 在无 GPU 或远程环境优先软件渲染，若有硬件加速可置为 0
export LIBGL_ALWAYS_SOFTWARE=${LIBGL_ALWAYS_SOFTWARE:-1}
# 常见布局用到的固定帧
export RVIZ_FIXED_FRAME=${RVIZ_FIXED_FRAME:-map}
# 避免某些 Wayland 合成器窗口装饰问题
export QT_WAYLAND_DISABLE_WINDOWDECORATION=${QT_WAYLAND_DISABLE_WINDOWDECORATION:-1}
